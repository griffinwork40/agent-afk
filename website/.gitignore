# Auto-generated by Next.js on every build — must not be committed.
next-env.d.ts

# Standalone npm app: the repo-root .gitignore ignores package-lock.json
# (pnpm convention), but this app needs its npm lockfile tracked for
# reproducible installs/deploys (esp. the pinned fumadocs-mdx version).
!package-lock.json
