# Anthropic API Configuration
# Use EITHER of the following (they're interchangeable):
# - ANTHROPIC_API_KEY: Get from https://console.anthropic.com/settings/keys
# - CLAUDE_CODE_OAUTH_TOKEN: OAuth token from Claude Code extension
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...your-token-here...

# Default Claude model (opus|sonnet|haiku)
CLAUDE_MODEL=sonnet

# Thinking & output budget (all optional; see `afk chat --help` for flags)
# - AFK_THINKING: 'adaptive' | 'disabled' | 'enabled:<N>' | 'enabled:max'
#   'enabled:max' uses the model's max-output cap minus a 1024-token margin.
# - AFK_EFFORT: low | medium | high | xhigh | max
#   ('xhigh' is Opus 4.7 only; 'max' is Opus 4.6/4.7 only.)
# - AFK_MAX_OUTPUT_TOKENS: positive integer or 'max'.
#   Propagates to the SDK subprocess as CLAUDE_CODE_MAX_OUTPUT_TOKENS.
#   'max' expands per-model: opus→128000, sonnet→64000, haiku→64000.
# AFK_THINKING=enabled:max
# AFK_EFFORT=max
# AFK_MAX_OUTPUT_TOKENS=max

# Telegram Bot Configuration (optional - for running npm run telegram)
# Get your bot token from @BotFather on Telegram:
#   1. Open Telegram, search for @BotFather
#   2. Send /newbot and follow instructions
#   3. Copy the token here
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_DATA_DIR=./data/telegram-sessions
# TELEGRAM_VERBOSE=false
#
# REQUIRED when running the bot: comma-separated Telegram chat IDs allowed to
# reach the agent. Fail-closed — the bot refuses to start if this is unset or
# empty, and silently drops updates from any chat not in the list. Negative
# IDs (groups/channels) are supported. Use @userinfobot to find your chat ID.
# AFK_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-100987654321

# Web search (optional - for web_scrape search mode)
# Brave Search API subscription token. Free tier at https://brave.com/search/api/.
# Without it, web_scrape search mode returns a clear error; markdown and raw
# modes work with no key. (markdown's render fallback needs the Playwright
# chromium binary: `pnpm exec playwright install chromium`.)
# BRAVE_SEARCH_API_KEY=BSA...your-token-here...

# Optional: Base URL and auth token (if using an Anthropic-compatible proxy)
# NOTE: This only works with proxies that speak Anthropic's /v1/messages API.
# Plain Ollama does NOT work here (Ollama uses its own API, not Anthropic's).
# Use an Anthropic-compatible proxy like claude-code-cursor-gateway or litellm.
# ANTHROPIC_BASE_URL=http://localhost:8000
# ANTHROPIC_AUTH_TOKEN=your-proxy-auth-token  # Some proxies require this instead of API_KEY
