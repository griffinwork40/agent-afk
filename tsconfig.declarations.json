{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "outDir": "./dist"
  },
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/**/*.test.ts",
    "src/**/__fixtures__/**",
    "src/**/__test-utils__/**"
  ]
}
